# ============================================================
# Options Flow Radar — Environment Variables
# Copy this file to .env and fill in values before running.
# ============================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment. Controls logging format (pretty in dev, JSON in prod).
# Values: development | production
APP_ENV=development

# Log level. Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string for the backend (asyncpg driver).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://ofr:ofr@localhost:5432/ofr

# ---------------------------------------------------------------------------
# Scanner
# ---------------------------------------------------------------------------

# Comma-separated list of underlying symbols to scan.
# Override SCANNER_UNIVERSE in the env as a JSON list if needed.
# Example: SCANNER_UNIVERSE=["SPY","QQQ","AAPL","NVDA"]
# Default defined in config.py if not set.

# How often (seconds) to run the full ingestion + signal cycle.
# Default: 300 (5 minutes).
SCAN_INTERVAL_SECONDS=300

# ---------------------------------------------------------------------------
# Signal Thresholds
# ---------------------------------------------------------------------------

# volume_ratio > this triggers at least MEDIUM alert.
VOLUME_SPIKE_THRESHOLD=2.0

# volume_ratio > this triggers at least HIGH alert (used in title heuristics).
VOLUME_SPIKE_HIGH=4.0

# Z-score threshold for volume anomaly detection.
ZSCORE_THRESHOLD=2.0

# Minimum volume for a contract to be considered by the signal engine.
MIN_VOLUME=100

# Number of past successful ingestion runs to use when computing baseline volume.
BASELINE_LOOKBACK_RUNS=20

# ---------------------------------------------------------------------------
# Data Provider (legacy global default)
# ---------------------------------------------------------------------------

# Fallback provider type for new tenants onboarded without an explicit
# TenantProviderConfig. Per-tenant provider is configured via the API:
#   POST /api/v1/tenants/{id}/providers
# Values: mock | polygon | tradier | ibkr | thetadata (register in providers/registry.py)
DATA_PROVIDER=mock

# ---------------------------------------------------------------------------
# Multi-tenant
# ---------------------------------------------------------------------------

# Fixed UUID for the default "system" workspace seeded on first startup.
# Change only if you need to migrate an existing deployment; aligns with migration 002.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_SLUG=default

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Base URL of the backend API. Used by the Next.js app to make API calls.
# In Docker Compose, the frontend is served client-side, so this must be
# the URL the *browser* can reach — typically http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000
